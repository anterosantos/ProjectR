{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "env",
            "importNames": ["SUPABASE_SERVICE_ROLE_KEY"],
            "message": "Service role key must only be used in API Routes / Server Actions / GitHub Actions. Never expose to client code. Use process.env directly in server-only files instead."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/**/*.ts", "src/**/*.tsx"],
      "rules": {
        "custom/no-direct-health-data-read": "warn"
      }
    },
    {
      "files": ["src/lib/data/audited.ts", "src/lib/actions/audit.ts"],
      "rules": {
        "custom/no-direct-health-data-read": "off"
      }
    }
  ]
}
