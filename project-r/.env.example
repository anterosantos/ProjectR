# Project R — Environment Variables Template
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit real secrets.
#
# Story 1.2 — Supabase Project Setup, DPA & DPIA Initial Documentation

# -----------------------------------------------------------------------------
# Supabase (PUBLIC — safe to expose to the browser)
# Get from: https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/api
#
# Naming note (2025+): Supabase renamed the legacy "anon key" to "publishable key"
# (prefix `sb_publishable_*`). The codebase uses NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY
# to match the dashboard label. If you have an old project with a JWT-style anon key,
# both names work with @supabase/ssr — pick one and stay consistent.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# -----------------------------------------------------------------------------
# App URL (used for auth callback redirects — e.g. password recovery email)
# Must be an absolute URL. In production: https://your-domain.com
# In local dev: http://localhost:3000
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase Service Role (SECRET — server-only, NEVER expose to the browser)
# Bypasses RLS — use ONLY in Edge Functions / Server Actions / GitHub Actions.
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -----------------------------------------------------------------------------
# Resend Email (SECRET — server-only)
# EU instance required (NFR30). Get from: https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=your-resend-api-key

# -----------------------------------------------------------------------------
# Web Push VAPID — for push notifications (Story 4.7)
# Generate with: `npx -y web-push generate-vapid-keys`
# Public is safe to expose; Private is server-only secret.
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# -----------------------------------------------------------------------------
# MFA Enforcement — Growth Phase (Story 1.7 AC #6)
# Comma-separated list of roles for which MFA is MANDATORY.
# When set, users with those roles who have no active MFA are prompted to enroll
# before accessing the app (enforced server-side via middleware / Edge Function).
# Default: empty string = MFA is OPTIONAL for all roles (MVP behaviour).
# Growth phase: set to "coach,analyst" to enforce MFA for staff roles.
# -----------------------------------------------------------------------------
MFA_REQUIRED_ROLES=

# -----------------------------------------------------------------------------
# Supabase DB URL (SECRET — used by GitHub Actions: heartbeat (1.14), backup (1.15))
# Direct PostgreSQL connection string (bypasses Supabase API layer).
# Format: postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres
# Get from: https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/database
# NEVER expose to the browser — server/CI only.
# -----------------------------------------------------------------------------
SUPABASE_DB_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Backup Encryption (SECRET — used by GitHub Actions backup.yml in Story 1.15)
# Generate a random 256-bit (32-byte) key via `openssl rand -base64 32` (generates 44 chars, 256-bit entropy).
# Use AES-256-GCM for authenticated encryption (GDPR Art. 32 requirement).
# -----------------------------------------------------------------------------
BACKUP_ENCRYPTION_KEY=your-random-256-bit-encryption-key

# -----------------------------------------------------------------------------
# Backup Repo Deploy Key (SECRET — used by GitHub Actions backup.yml in Story 1.15)
# SSH private key (ed25519) with write access to the private `project-r-backups` repo.
# Generate with: `ssh-keygen -t ed25519 -f backup_deploy_key -N "" -C "backup-workflow"`
# Add the public key as a Deploy Key (with write access) in the project-r-backups repo.
# Add this private key as the BACKUP_REPO_DEPLOY_KEY secret in this repo.
# Delete both key files locally after setup.
# -----------------------------------------------------------------------------
BACKUP_REPO_DEPLOY_KEY=-----BEGIN OPENSSH PRIVATE KEY-----your-ed25519-private-key-----END OPENSSH PRIVATE KEY-----
