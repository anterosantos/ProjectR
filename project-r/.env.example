# Supabase Configuration
# Copy this file to .env.local and fill in your project credentials
# Get these values from: https://app.supabase.com/project/[YOUR_PROJECT_ID]/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

